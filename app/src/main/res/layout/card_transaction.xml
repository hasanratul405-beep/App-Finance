<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="420dp"
    android:background="@drawable/card_bg"
    android:padding="0dp">

    <!-- Drag handle at very top center -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:background="@drawable/drag_handle"
        android:layout_alignParentTop="true"/>

    <!-- Type pill -->
    <TextView
        android:id="@+id/typePill"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:background="@drawable/pill_bg"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="CREDIT RECEIVED"
        android:textColor="@color/blue"
        android:textSize="9sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:layout_alignParentTop="true"/>

    <!-- Content block (centered in card) -->
    <LinearLayout
        android:id="@+id/contentBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/typePill"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="28dp">

        <!-- Bank/Account icon circle -->
        <RelativeLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/icon_circle">

            <TextView
                android:id="@+id/bankInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="B"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold"/>
        </RelativeLayout>

        <!-- Bank name -->
        <TextView
            android:id="@+id/bankName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dutch-Bangla Bank"
            android:textColor="@color/text1"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"/>

        <!-- Matched account -->
        <TextView
            android:id="@+id/matchedAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Matched: Business Expenses"
            android:textColor="@color/green"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:visibility="gone"/>

        <!-- View details -->
        <TextView
            android:id="@+id/viewDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="View SMS details"
            android:textColor="@color/text2"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:paddingBottom="2dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"/>

        <!-- Transaction type label -->
        <TextView
            android:id="@+id/txTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount"
            android:textColor="@color/text2"
            android:textSize="12sp"
            android:letterSpacing="0.05"/>

        <!-- Amount -->
        <TextView
            android:id="@+id/amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="৳ 12,500"
            android:textColor="@color/text1"
            android:textSize="34sp"
            android:fontFamily="sans-serif-bold"/>

        <!-- Date -->
        <TextView
            android:id="@+id/txDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="March 26, 2026"
            android:textColor="@color/text2"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Bottom action buttons (pinned to bottom of card) -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/rejectBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_reject"
                android:text="Reject"
                android:textColor="@color/text1"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/acceptBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/btn_accept"
                android:text="Accept"
                android:textColor="@color/navy"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <TextView
            android:id="@+id/skipBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Skip for later"
            android:textColor="@color/text2"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>

    </LinearLayout>

    <!-- Swipe overlay indicators -->
    <TextView
        android:id="@+id/acceptOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:background="@drawable/pill_accept"
        android:padding="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="ACCEPT"
        android:textColor="@color/navy"
        android:textSize="12sp"
        android:fontFamily="sans-serif-bold"
        android:visibility="invisible"/>

    <TextView
        android:id="@+id/rejectOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="24dp"
        android:background="@drawable/pill_reject"
        android:padding="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:text="REJECT"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:fontFamily="sans-serif-bold"
        android:visibility="invisible"/>

</RelativeLayout>
