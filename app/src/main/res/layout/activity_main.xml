<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Pending transactions bar - shown when SMS detects transactions -->
    <LinearLayout
        android:id="@+id/pendingBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentBottom="true"
        android:background="@color/mid"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <!-- Pulsing dot -->
        <View
            android:id="@+id/pulseDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_green"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/pendingText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2 new transactions detected"
            android:textColor="@color/text1"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/reviewBtn"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/btn_blue"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Review"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

</RelativeLayout>
